<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<AnchorPane prefHeight="660.0" prefWidth="900.0" style="-fx-background-color: #F0EDE4;"
            stylesheets="@style.css" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="GuestChatController">

    <fx:include fx:id="navBar" source="NavgationBar.fxml" />

    <HBox layoutY="71" prefHeight="589" prefWidth="900">

        <fx:include fx:id="sidebar" source="GuestSidebar.fxml" />

        <VBox prefWidth="680" spacing="0" style="-fx-background-color: #F0EDE4;">

            <VBox styleClass="chat-header" spacing="2">
                <padding><Insets bottom="14" left="24" right="24" top="14" /></padding>
                <Label styleClass="chat-header-title" text="FRONT DESK" />
                <Label fx:id="lblStatus" styleClass="chat-header-status" text="Connecting..." />
            </VBox>

            <Pane prefHeight="2" style="-fx-background-color: #C9A84C;" />

            <ScrollPane fx:id="messagesScroll" fitToWidth="true" VBox.vgrow="ALWAYS"
                        styleClass="chat-scroll">
                <VBox fx:id="messagesBox" spacing="10" styleClass="chat-messages-box">
                    <padding><Insets bottom="20" left="20" right="20" top="20" /></padding>
                </VBox>
            </ScrollPane>

            <HBox styleClass="chat-input-bar" spacing="10" alignment="CENTER">
                <padding><Insets bottom="14" left="20" right="20" top="14" /></padding>
                <TextField fx:id="txtMessage" promptText="Type your message..."
                           styleClass="chat-input" HBox.hgrow="ALWAYS"
                           onAction="#handleSend" />
                <Button fx:id="btnSend" text="Send" styleClass="btn-chat-send"
                        onAction="#handleSend" />
            </HBox>

        </VBox>
    </HBox>
</AnchorPane>

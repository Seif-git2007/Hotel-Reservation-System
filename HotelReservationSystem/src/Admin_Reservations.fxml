<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Pane?>
<?import javafx.scene.layout.VBox?>

<AnchorPane prefHeight="660.0" prefWidth="900.0"
            style="-fx-background-color: #F0EDE4;"
            stylesheets="@style.css"
            xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="AdminReservationsController">

    <fx:include fx:id="navBar" layoutX="0" layoutY="0" source="NavgationBar.fxml" />

    <HBox layoutX="0" layoutY="71" prefHeight="589" prefWidth="900" spacing="0">

        <fx:include fx:id="sidebar" source="AdminSidebar.fxml" />

        <VBox prefWidth="680" prefHeight="589" spacing="0"
              style="-fx-background-color: #F0EDE4;">

            <!-- Page header -->
            <HBox alignment="CENTER_LEFT" prefWidth="680" spacing="12" styleClass="page-header-strip">
                <Pane prefHeight="32" prefWidth="4"
                      style="-fx-background-color: #C9A84C; -fx-background-radius: 2;" />
                <VBox spacing="2">
                    <Label styleClass="label-dashboard-title" text="Reservations" />
                    <Label styleClass="label-dashboard-sub"
                           text="View and filter all guest reservations" />
                </VBox>
                <Pane HBox.hgrow="ALWAYS" />

                <!-- Filter ComboBox -->
                <ComboBox fx:id="filterCombo"
                          promptText="All Statuses"
                          styleClass="filter-combo"
                          prefHeight="36" prefWidth="160">
                    <HBox.margin><Insets right="20" /></HBox.margin>
                </ComboBox>
            </HBox>

            <!-- Stats strip -->
            <HBox spacing="0" prefWidth="680"
                  style="-fx-background-color: #0F2160; -fx-padding: 10 20 10 20;">
                <Label fx:id="lblTotal"
                       style="-fx-text-fill: rgba(255,255,255,0.70); -fx-font-size: 12px; -fx-font-weight: bold;" />
                <Pane HBox.hgrow="ALWAYS" />
                <Label fx:id="lblPending"
                       style="-fx-text-fill: #C9A84C; -fx-font-size: 12px; -fx-font-weight: bold;">
                    <HBox.margin><Insets right="20" /></HBox.margin>
                </Label>
                <Label fx:id="lblConfirmed"
                       style="-fx-text-fill: #4CAF50; -fx-font-size: 12px; -fx-font-weight: bold;">
                    <HBox.margin><Insets right="20" /></HBox.margin>
                </Label>
                <Label fx:id="lblCompleted"
                       style="-fx-text-fill: rgba(255,255,255,0.50); -fx-font-size: 12px; -fx-font-weight: bold;" />
            </HBox>

            <!-- Reservation list -->
            <VBox VBox.vgrow="ALWAYS" spacing="0">
                <ScrollPane fitToWidth="true"
                            style="-fx-background-color: transparent; -fx-background: #F0EDE4;"
                            VBox.vgrow="ALWAYS" styleClass="register-scroll">
                    <content>
                        <VBox fx:id="reservationList" spacing="12"
                              style="-fx-background-color: #F0EDE4;">
                            <padding>
                                <Insets bottom="24" left="20" right="20" top="20" />
                            </padding>
                        </VBox>
                    </content>
                </ScrollPane>
            </VBox>

        </VBox>
    </HBox>
</AnchorPane>
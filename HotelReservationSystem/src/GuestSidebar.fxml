<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.Pane?>
<?import javafx.scene.layout.VBox?>


<VBox prefHeight="589" prefWidth="220"
      spacing="0"
      styleClass="sidebar-panel"
      stylesheets="@style.css"
      xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="GuestSidebarController">


    <VBox alignment="CENTER" spacing="4" styleClass="sidebar-brand-card">
        <VBox.margin><Insets bottom="6" left="16" right="16" top="24" /></VBox.margin>
        <Label styleClass="sidebar-brand-wordmark" text="Kempinski" />
        <Label styleClass="sidebar-brand-sub" text="GUEST PORTAL" />
        <Pane prefHeight="1.5" prefWidth="80" style="-fx-background-color: #C9A84C;">
            <VBox.margin><Insets top="6" /></VBox.margin>
        </Pane>
    </VBox>


    <Label styleClass="sidebar-section-label" text="MENU">
        <VBox.margin><Insets bottom="4" left="20" top="16" /></VBox.margin>
    </Label>


    <Button fx:id="btnViewRooms"
            text="🛏  View Rooms"
            onAction="#goViewRooms"
            prefHeight="50" prefWidth="220"
            styleClass="sidebar-nav-btn"
            mnemonicParsing="false"/>

    <Button fx:id="btnMakeReservation"
            text="📅  Make Reservation"
            onAction="#goMakeReservation"
            prefHeight="50" prefWidth="220"
            styleClass="sidebar-nav-btn"
            mnemonicParsing="false"/>

    <Button fx:id="btnViewReservations"
            text="📋  View Reservations"
            onAction="#goViewReservations"
            prefHeight="50" prefWidth="220"
            styleClass="sidebar-nav-btn"
            mnemonicParsing="false"/>

    <Button fx:id="btnCancelReservation"
            text="❌  Cancel Reservation"
            onAction="#goCancelReservation"
            prefHeight="50" prefWidth="220"
            styleClass="sidebar-nav-btn"
            mnemonicParsing="false"/>

    <Button fx:id="btnCheckOut"
            text="🚪  Check Out"
            onAction="#goCheckOut"
            prefHeight="50" prefWidth="220"
            styleClass="sidebar-nav-btn"
            mnemonicParsing="false"/>

    <Pane VBox.vgrow="ALWAYS" />
    <Pane prefHeight="1" prefWidth="220"
          style="-fx-background-color: rgba(201,168,76,0.30);" />

</VBox>

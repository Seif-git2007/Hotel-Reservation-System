<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Pane?>
<?import javafx.scene.layout.VBox?>

<AnchorPane prefHeight="660.0" prefWidth="900.0"
            style="-fx-background-color: #F0EDE4;"
            stylesheets="@style.css"
            xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="ReceptionistMenuController">

    <fx:include fx:id="navBar" layoutX="0" layoutY="0" source="NavgationBar.fxml" />

    <HBox layoutX="0" layoutY="71" prefHeight="589" prefWidth="900" spacing="0">

        <fx:include fx:id="sidebar" source="Receptionistsidebar.fxml" />

        <VBox prefWidth="680" prefHeight="589" spacing="0"
              style="-fx-background-color: #F0EDE4;">

            <!-- Page header -->
            <HBox alignment="CENTER_LEFT" prefWidth="680" spacing="12" styleClass="page-header-strip">
                <Pane prefHeight="32" prefWidth="4"
                      style="-fx-background-color: #C9A84C; -fx-background-radius: 2;" />
                <VBox spacing="2">
                    <Label styleClass="label-dashboard-title" text="Receptionist Panel" />
                    <Label styleClass="label-dashboard-sub"
                           text="Manage today's arrivals, departures and all reservations" />
                </VBox>
            </HBox>

            <!-- Welcome block -->
            <VBox alignment="CENTER_LEFT" spacing="4">
                <VBox.margin><Insets left="32" top="24" bottom="8" /></VBox.margin>
                <Label style="-fx-text-fill: #0F2160;
                              -fx-font-family: 'Georgia';
                              -fx-font-size: 20px;
                              -fx-font-style: italic;"
                       text="Welcome back," />
                <Label fx:id="welcomeName"
                       style="-fx-text-fill: #C9A84C;
                              -fx-font-size: 16px;
                              -fx-font-weight: bold;"
                       text="Receptionist" />
            </VBox>

            <!-- Three luxury stat boxes -->
            <HBox spacing="16" prefWidth="680" alignment="CENTER">
                <VBox.margin><Insets top="20" left="24" right="24" bottom="0" /></VBox.margin>

                <!-- Check-ins -->
                <VBox HBox.hgrow="ALWAYS" spacing="0"
                      style="-fx-background-color: #FFFFFF;
                             -fx-background-radius: 12;
                             -fx-border-color: #E0DAD0;
                             -fx-border-radius: 12;
                             -fx-border-width: 0.5;
                             -fx-effect: dropshadow(three-pass-box, rgba(15,33,96,0.06), 8, 0, 0, 2);">

                    <Pane prefHeight="4"
                          style="-fx-background-color: #C9A84C;
                                 -fx-background-radius: 12 12 0 0;" />

                    <VBox spacing="6" alignment="CENTER"
                          style="-fx-padding: 24 20 24 20;">
                        <Label text="🛎" style="-fx-font-size: 28px;" />
                        <Label text="CHECK-INS TODAY"
                               style="-fx-text-fill: #9B9589;
                                      -fx-font-size: 10px;
                                      -fx-font-weight: bold;
                                      -fx-letter-spacing: 0.14em;" />
                        <Label fx:id="lblCheckInCount"
                               style="-fx-text-fill: #0F2160;
                                      -fx-font-family: 'Georgia', serif;
                                      -fx-font-size: 42px;
                                      -fx-font-weight: bold;"
                               text="0" />
                        <Label text="pending arrivals"
                               style="-fx-text-fill: #9B9589;
                                      -fx-font-size: 11px;
                                      -fx-font-style: italic;" />
                    </VBox>
                </VBox>

                <!-- Check-outs -->
                <VBox HBox.hgrow="ALWAYS" spacing="0"
                      style="-fx-background-color: #FFFFFF;
                             -fx-background-radius: 12;
                             -fx-border-color: #E0DAD0;
                             -fx-border-radius: 12;
                             -fx-border-width: 0.5;
                             -fx-effect: dropshadow(three-pass-box, rgba(15,33,96,0.06), 8, 0, 0, 2);">

                    <Pane prefHeight="4"
                          style="-fx-background-color: #C9A84C;
                                 -fx-background-radius: 12 12 0 0;" />

                    <VBox spacing="6" alignment="CENTER"
                          style="-fx-padding: 24 20 24 20;">
                        <Label text="🚪" style="-fx-font-size: 28px;" />
                        <Label text="CHECK-OUTS TODAY"
                               style="-fx-text-fill: #9B9589;
                                      -fx-font-size: 10px;
                                      -fx-font-weight: bold;
                                      -fx-letter-spacing: 0.14em;" />
                        <Label fx:id="lblCheckOutCount"
                               style="-fx-text-fill: #C9A84C;
                                      -fx-font-family: 'Georgia', serif;
                                      -fx-font-size: 42px;
                                      -fx-font-weight: bold;"
                               text="0" />
                        <Label text="departures due"
                               style="-fx-text-fill: #9B9589;
                                      -fx-font-size: 11px;
                                      -fx-font-style: italic;" />
                    </VBox>
                </VBox>

                <!-- Total reservations -->
                <VBox HBox.hgrow="ALWAYS" spacing="0"
                      style="-fx-background-color: #FFFFFF;
                             -fx-background-radius: 12;
                             -fx-border-color: #E0DAD0;
                             -fx-border-radius: 12;
                             -fx-border-width: 0.5;
                             -fx-effect: dropshadow(three-pass-box, rgba(15,33,96,0.06), 8, 0, 0, 2);">

                    <Pane prefHeight="4"
                          style="-fx-background-color: #C9A84C;
                                 -fx-background-radius: 12 12 0 0;" />

                    <VBox spacing="6" alignment="CENTER"
                          style="-fx-padding: 24 20 24 20;">
                        <Label text="📋" style="-fx-font-size: 28px;" />
                        <Label text="TOTAL RESERVATIONS"
                               style="-fx-text-fill: #9B9589;
                                      -fx-font-size: 10px;
                                      -fx-font-weight: bold;
                                      -fx-letter-spacing: 0.14em;" />
                        <Label fx:id="lblReservationCount"
                               style="-fx-text-fill: #0F2160;
                                      -fx-font-family: 'Georgia', serif;
                                      -fx-font-size: 42px;
                                      -fx-font-weight: bold;"
                               text="0" />
                        <Label text="in the system"
                               style="-fx-text-fill: #9B9589;
                                      -fx-font-size: 11px;
                                      -fx-font-style: italic;" />
                    </VBox>
                </VBox>

            </HBox>

            <!-- Gold divider line -->
            <Pane prefHeight="1.5" prefWidth="640"
                  style="-fx-background-color: rgba(201,168,76,0.25);">
                <VBox.margin><Insets top="28" left="24" right="24" /></VBox.margin>
            </Pane>

            <!-- Footer hint -->
            <VBox alignment="CENTER" VBox.vgrow="ALWAYS">
                <Label style="-fx-text-fill: rgba(107,107,107,0.45);
                              -fx-font-family: 'Georgia', serif;
                              -fx-font-size: 13px;
                              -fx-font-style: italic;"
                       text="Use the sidebar to manage check-ins, check-outs, guests and rooms." />
            </VBox>

        </VBox>
    </HBox>
</AnchorPane>
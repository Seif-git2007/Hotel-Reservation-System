<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Pane?>
<?import javafx.scene.layout.VBox?>

<AnchorPane prefHeight="660.0" prefWidth="900.0" style="-fx-background-color: #F0EDE4;" stylesheets="@style.css" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="MakeReservationController">

    <fx:include fx:id="navBar" layoutX="0" layoutY="0" source="NavgationBar.fxml" />

    <HBox layoutX="0" layoutY="71" prefHeight="589" prefWidth="900" spacing="0">

        <fx:include fx:id="sidebar" source="GuestSidebar.fxml" />

        <VBox prefHeight="589" prefWidth="680" spacing="0" style="-fx-background-color: #F0EDE4;">

            <HBox alignment="CENTER_LEFT" prefWidth="680" spacing="12" styleClass="page-header-strip">
                <Pane prefHeight="32" prefWidth="4" style="-fx-background-color: #C9A84C; -fx-background-radius: 2;" />
                <VBox spacing="2">
                    <Label styleClass="label-dashboard-title" text="Make Reservation" />
                    <Label styleClass="label-dashboard-sub" text="Choose your dates and room" />
                </VBox>
            </HBox>

            <VBox alignment="CENTER" style="-fx-background-color: #F0EDE4;" VBox.vgrow="ALWAYS">
                <HBox prefHeight="81.0" prefWidth="670.0" spacing="20.0">
                    <VBox.margin><Insets left="10.0" /></VBox.margin>
                    <VBox prefHeight="92.0" prefWidth="209.0">
                        <Label styleClass="label-field" text="Check-in Date" />
                        <DatePicker fx:id="checkInDate" prefHeight="38.0" prefWidth="209.0" styleClass="register-datepicker">
                            <VBox.margin><Insets top="7.0" /></VBox.margin>
                        </DatePicker>
                    </VBox>
                    <VBox prefHeight="100.0" prefWidth="215.0">
                        <Label styleClass="label-field" text="Check-out Date" />
                        <DatePicker fx:id="checkOutDate" prefHeight="40.0" prefWidth="214.0" styleClass="register-datepicker">
                            <VBox.margin><Insets top="7.0" /></VBox.margin>
                        </DatePicker>
                    </VBox>
                    <VBox prefHeight="100.0" prefWidth="208.0">
                        <Button mnemonicParsing="false" onAction="#search" text="Search🔍">
                            <VBox.margin><Insets left="80.0" top="20.0" /></VBox.margin>
                        </Button>
                    </VBox>
                </HBox>
            <VBox prefHeight="200.0" prefWidth="100.0">
               <children>
                  <Label fx:id="errorLabel" styleClass="label-error" text="Label" visible="false">
                     <opaqueInsets>
                        <Insets />
                     </opaqueInsets>
                     <VBox.margin>
                        <Insets />
                     </VBox.margin>
                     <padding>
                        <Insets left="12.0" top="20.0" />
                     </padding>
                  </Label>
               </children>
            </VBox>
                <VBox minHeight="-Infinity" prefHeight="410.0" prefWidth="680.0">
                    <ScrollPane prefHeight="425.0" prefWidth="680.0" styleClass="register-scroll">
                        <content>
                            <VBox fx:id="roomContainer" prefWidth="673.0" spacing="15" style="-fx-background-color: #F0EDE4;">
                                <padding>
                                    <Insets bottom="20" left="20" right="20" top="20" />
                                </padding>
                            </VBox>
                        </content>
                    </ScrollPane>
                </VBox>
            </VBox>

        </VBox>
    </HBox>
</AnchorPane>

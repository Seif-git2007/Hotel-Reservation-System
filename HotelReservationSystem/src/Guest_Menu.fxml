<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Pane?>
<?import javafx.scene.layout.VBox?>

<!--
  GUEST MENU — matches screenshot 6 exactly
  Navbar | "Guest Portal" header | My Bookings / Room Service / My Profile cards (empty)
  | Main content placeholder
  Size: 900 x 660
-->
<AnchorPane
        prefHeight="660.0" prefWidth="900.0"
        style="-fx-background-color: #F0EDE4;"
        stylesheets="@style.css"
        xmlns="http://javafx.com/javafx/21"
        xmlns:fx="http://javafx.com/fxml/1">

    <!-- Navigation Bar -->
    <fx:include source="NavgationBar.fxml" layoutX="0" layoutY="0" fx:id="navBar" />

    <!-- ══ CONTENT ══ -->
    <VBox
            layoutX="0" layoutY="71"
            prefWidth="900" prefHeight="589"
            styleClass="content-area"
            spacing="0">

        <!-- Page header -->
        <HBox styleClass="page-header-strip" prefWidth="900" alignment="CENTER_LEFT" spacing="14">
            <Pane styleClass="page-title-accent" prefHeight="46" />
            <VBox spacing="4">
                <Label text="Guest Portal" styleClass="label-dashboard-title" />
                <Label text="View your reservations, services, and preferences" styleClass="label-dashboard-sub" />
            </VBox>
        </HBox>

        <!-- Section cards row -->
        <HBox spacing="20" prefWidth="900">
            <VBox.margin><Insets top="20" left="24" right="24" bottom="16" /></VBox.margin>

            <!-- My Bookings -->
            <VBox styleClass="section-card" HBox.hgrow="ALWAYS" spacing="10">
                <Label text="My Bookings" styleClass="section-card-title" />
                <!-- ╔══════════════════════════════╗
                     ║  Add My Bookings content     ║
                     ╚══════════════════════════════╝ -->
                <Pane prefHeight="148" />
            </VBox>

            <!-- Room Service -->
            <VBox styleClass="section-card" HBox.hgrow="ALWAYS" spacing="10">
                <Label text="Room Service" styleClass="section-card-title" />
                <!-- ╔══════════════════════════════╗
                     ║  Add Room Service content    ║
                     ╚══════════════════════════════╝ -->
                <Pane prefHeight="148" />
            </VBox>

            <!-- My Profile -->
            <VBox styleClass="section-card" HBox.hgrow="ALWAYS" spacing="10">
                <Label text="My Profile" styleClass="section-card-title" />
                <!-- ╔══════════════════════════════╗
                     ║  Add My Profile content      ║
                     ╚══════════════════════════════╝ -->
                <Pane prefHeight="148" />
            </VBox>

        </HBox>

        <!-- Main content placeholder -->
        <VBox styleClass="main-content-card" prefWidth="852" VBox.vgrow="ALWAYS" alignment="CENTER">
            <VBox.margin><Insets left="24" right="24" bottom="24" /></VBox.margin>
            <Label text="Main content area — add your components here"
                   styleClass="main-content-hint" />
        </VBox>

    </VBox>

</AnchorPane>
